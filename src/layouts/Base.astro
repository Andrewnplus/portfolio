---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Andrew Yang — backend engineer. Data pipelines, message queues, KPI services, and large-scale automation.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const path = Astro.url.pathname;
const current = (p: string) => (path === `${base}${p}` || path === `${base}${p}/` ? 'page' : undefined);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrap">
      <nav class="site">
        <a class="brand" href={`${base}/`}>Andrew Yang</a>
        <a href={`${base}/work/`} aria-current={current('/work')}>Work</a>
        <a href={`${base}/platform/`} aria-current={current('/platform')}>Platform</a>
        <a href={`${base}/demo/`} aria-current={current('/demo')}>Demo</a>
        <a href={`${base}/about/`} aria-current={current('/about')}>About</a>
      </nav>
      <main>
        <slot />
      </main>
      <footer class="site">
        <span>© {new Date().getFullYear()} Andrew Yang · </span>
        <a href="https://github.com/Andrewnplus">GitHub</a> ·
        <a href="mailto:andrew.nplus@gmail.com">Email</a>
      </footer>
    </div>
  </body>
</html>
